# Copy to `backend/.env` or `backend/local.env` (local.env overrides — see app-mongodb.ts)

# Database (required for a real deployment; local default is mongodb://localhost:27017/larkon-fashion if unset)
# MONGODB_URI=mongodb://localhost:27017/larkon-fashion

PORT=5001

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Seed / default admin (used on first run if no admin exists)
ADMIN_EMAIL=admin@larkon.com
ADMIN_PASSWORD=admin123

# CORS — include your admin origin(s)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Uploads
# UPLOAD_PATH=./uploads
# MAX_FILE_SIZE=20971520

# Stripe (optional — needed for payments / webhooks)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_CURRENCY=pkr
