NODE_ENV=production
PORT=5000
JWT_SECRET=your_jwt_secret_here
MONGODB_URI='mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=Cluster0'
ALLOWED_ORIGINS=https://admin.buyshopo.com,https://buyshopo.com,https://www.buyshopo.com
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=20971520
# Stripe — replace with your actual keys from the Stripe dashboard
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CURRENCY=pkr
