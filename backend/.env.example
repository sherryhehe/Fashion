# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/fashion

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19000

# Stripe (optional – when set, card orders use Stripe; payouts go to your Stripe-connected bank)
STRIPE_SECRET_KEY=sk_test_xxxx
# Stripe webhook signing secret (for POST /api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=whsec_xxxx
# Currency for Stripe (pkr or usd). PKR amount is sent in paisa (total * 100)
STRIPE_CURRENCY=pkr
