# Copy to `admin/.env.local` (Next.js loads this automatically).

# Local dev already uses http://localhost:5001/api when you open the admin on localhost
# (see src/utils/apiHelper.ts). Default port 5001 avoids macOS using :5000 for AirPlay.

# NEXT_PUBLIC_API_URL_LOCAL=http://localhost:5001/api

# Set to true to use NEXT_PUBLIC_API_URL / production-style routing instead of local API:
# NEXT_PUBLIC_USE_REMOTE_API=false

# Full API URL when not on localhost (or when USE_REMOTE_API is true):
# NEXT_PUBLIC_API_URL=https://api.example.com/api

# If image URLs need a different public origin than the API host:
# NEXT_PUBLIC_IMAGE_BASE_URL=http://localhost:5001

# Optional branding / flags
# NEXT_PUBLIC_APP_NAME=Shopo Admin Dashboard
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_DEBUG_MODE=true
