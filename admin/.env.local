# Local admin → local backend (Stripe status, etc.). Backend port must match (see backend PORT / local.env).
NEXT_PUBLIC_API_URL_LOCAL=http://localhost:5000/api

# Set to true only if you want localhost:3000 admin to hit production API instead:
# NEXT_PUBLIC_USE_REMOTE_API=true
# NEXT_PUBLIC_API_URL=https://admin.buyshopo.com/api
